# Kena environment template — copy to .env.local and fill in
# Per D7 §2 (tech stack) and D10 §2.3 step 10
# NEVER commit .env or .env.local — both are in .gitignore

# ────────────────────────────────────────────────────────────────────────
# Supabase (D7 §2.2)
# ────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only (edge functions, never bundled in mobile build)
SUPABASE_SERVICE_ROLE_KEY=

# ────────────────────────────────────────────────────────────────────────
# AI gateway (D7 §2.3) — LiteLLM proxy on Hetzner
# ────────────────────────────────────────────────────────────────────────
LITELLM_BASE_URL=
LITELLM_API_KEY=
# Direct Anthropic key — used only in dev / by LiteLLM upstream
ANTHROPIC_API_KEY=

# ────────────────────────────────────────────────────────────────────────
# RevenueCat (D7 §2.4) — paywall + IAP
# ────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

# ────────────────────────────────────────────────────────────────────────
# Push (D7 §2.5) — Expo Notifications
# ────────────────────────────────────────────────────────────────────────
EXPO_PROJECT_ID=
EXPO_PUSH_ACCESS_TOKEN=

# ────────────────────────────────────────────────────────────────────────
# Analytics (D7 §2.6) — PostHog self-hosted
# ────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_POSTHOG_HOST=
EXPO_PUBLIC_POSTHOG_API_KEY=

# ────────────────────────────────────────────────────────────────────────
# Error tracking (D7 §2.7) — Sentry SaaS Team plan
# ────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ────────────────────────────────────────────────────────────────────────
# OAuth — Apple + Google (D7 §6.1)
# ────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_OAUTH_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=

# ────────────────────────────────────────────────────────────────────────
# n8n webhooks (D7 §2.2) — workflow orchestration
# ────────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_SECRET=
