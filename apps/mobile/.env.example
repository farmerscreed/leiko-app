# Copy to .env.local (gitignored) and fill from `supabase status` after
# running `supabase start` from the repo root.
#
# EXPO_PUBLIC_* vars are baked into the JS bundle at build time. Only put
# values here that are safe to ship to the client (the anon/publishable
# key is — it's RLS-gated on the server side).
#
# IMPORTANT — pick the URL based on where the app runs:
#   - Physical phone on the same Wi-Fi: use the dev machine's LAN IP
#     (e.g. http://192.168.0.166:54321). 127.0.0.1 from a phone is the
#     phone's own loopback, not the dev machine.
#   - Android emulator: http://10.0.2.2:54321 (its host alias).
#   - iOS simulator: http://127.0.0.1:54321 (shares the host's loopback).
#   - Node smoke tests on the dev machine: http://127.0.0.1:54321.
#
# Supabase CLI 2.98+ prints `Publishable` (sb_publishable_*) instead of
# the legacy anon JWT. supabase-js 2.105+ accepts both formats; put
# whichever your CLI prints into the ANON_KEY var below.

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=
