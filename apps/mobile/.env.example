# Copy to .env.local (gitignored) and fill from `supabase status` after
# running `supabase start` from the repo root.
#
# EXPO_PUBLIC_* vars are baked into the JS bundle at build time. Only put
# values here that are safe to ship to the client (the anon key is — it's
# RLS-gated on the server side).

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=
