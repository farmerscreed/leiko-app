{
  "expo": {
    "name": "Leiko",
    "slug": "leiko",
    "version": "0.0.0",
    "scheme": "leiko",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.leiko.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Leiko uses Bluetooth to talk to your watch and sync readings.",
        "NSBluetoothPeripheralUsageDescription": "Leiko uses Bluetooth to talk to your watch.",
        "UIBackgroundModes": [
          "bluetooth-central"
        ]
      }
    },
    "android": {
      "package": "com.leiko.app",
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
      ]
    },
    "plugins": [
      "expo-font",
      "@kingstinct/react-native-healthkit",
      "react-native-health-connect"
    ]
  }
}
